{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm ci --prefix client",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/internal/(.*)", "destination": "/api/index.py" },
    { "source": "/health", "destination": "/api/index.py" },
    { "source": "/docs", "destination": "/api/index.py" },
    { "source": "/docs/(.*)", "destination": "/api/index.py" },
    { "source": "/openapi.json", "destination": "/api/index.py" },
    {
      "source": "/((?!api/|internal/|health|docs|openapi\\.json|assets/|favicon\\.svg|icons\\.svg).*)",
      "destination": "/index.html"
    }
  ]
}
